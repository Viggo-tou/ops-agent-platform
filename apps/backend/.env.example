# Copy to `.env` and fill in the values you need. `.env` is git-ignored.
# The platform falls back to mock providers when LLM keys are missing,
# so the API surface (http://127.0.0.1:8000/docs) is browsable without
# any keys.

# ---- Database ----
# Postgres (preferred — what docker-compose.yml uses):
DATABASE_URL=postgresql+psycopg://ops_agent:ops_agent_dev_password@localhost:5433/ops_agent_platform
# SQLite fallback for quick local hacks (no docker required):
# DATABASE_URL=sqlite:///./ops_agent_platform.db

# ---- LLM providers (all optional; mock fallback otherwise) ----
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# MINIMAX_API_KEY=eyJ...

# ---- MCP servers (optional) ----
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=ATATT...
